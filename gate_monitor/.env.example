# ─── Camera Source ───────────────────────────────────────
# 0           = default USB webcam
# 1, 2, ...   = other USB cameras
# rtsp://...  = IP camera stream
# path/to/video.mp4  = video file (for testing)
CAMERA_SOURCE=0

# ─── Gate Identity ───────────────────────────────────────
GATE_ID=A
GATE_LOCATION=Main Entrance, North

# ─── Backend API ─────────────────────────────────────────
API_URL=http://localhost:5000/api/traffic/add
API_KEY=your-secret-api-key-here

# ─── Detection Settings ──────────────────────────────────
# Confidence threshold for YOLOv8 person detection (0.0–1.0)
CONFIDENCE_THRESHOLD=0.45

# Virtual line position as a fraction of frame height (0.0 = top, 1.0 = bottom)
LINE_POSITION=0.5

# How often (seconds) to POST aggregate counts to the Flask backend
POST_INTERVAL_SEC=30

# YOLOv8 model size: yolov8n (fastest), yolov8s, yolov8m, yolov8l, yolov8x (most accurate)
YOLO_MODEL=yolov8n.pt

# Show live video window (true/false) — set false for headless/server deployment
SHOW_WINDOW=true
