# ─── Core ───────────────────────────────────────────────
SECRET_KEY=change-me-before-deploying-to-production
DEBUG=true

# ─── Database ────────────────────────────────────────────
# SQLite (default, zero setup needed):
DATABASE_URL=sqlite:///smart_campus.db

# PostgreSQL example (uncomment for production):
# DATABASE_URL=postgresql://user:password@localhost:5432/smart_campus

# ─── JWT ─────────────────────────────────────────────────
JWT_SECRET_KEY=jwt-super-secret-change-me
JWT_EXPIRES_HOURS=24

# ─── CORS ────────────────────────────────────────────────
# Comma-separated list of allowed origins (* = all, fine for development)
CORS_ORIGINS=*

# ─── Congestion Thresholds ───────────────────────────────
AI_CONGESTION_THRESHOLD=200
AI_CRITICAL_THRESHOLD=350

# ─── Capacity Management ─────────────────────────────────
DEFAULT_GLOBAL_CAPACITY=50
DEFAULT_WARNING_THRESHOLD=0.7
DEFAULT_CRITICAL_THRESHOLD=0.9

# ─── API Authentication ──────────────────────────────────
API_KEY=smartcampus-secret-key-2026

# ─── AI / LLM (optional) ─────────────────────────────────
# Set USE_LLM=true and fill in the key to use a real AI model.
# Leave USE_LLM=false to use the built-in rule-based engine (default).
USE_LLM=false
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-your-openai-key-here
